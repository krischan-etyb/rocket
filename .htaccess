# Force all requests through Passenger (Flask app)
# This ensures Flask handles routing for /calculator/bg/, /api/*, etc.

PassengerEnabled on
PassengerAppRoot /home/YOUR_JETHOST_USERNAME/public_html

# If your Python is in a virtualenv, uncomment and adjust:
# PassengerPython /home/YOUR_JETHOST_USERNAME/virtualenv/python3.10/bin/python3

# Redirect www to non-www (optional, uncomment if needed)
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.r-logistic\.com$ [NC]
# RewriteRule ^(.*)$ https://r-logistic.com/$1 [R=301,L]
