# Force all requests through Passenger (Flask app)
# This ensures Flask handles routing for /calculator/bg/, /api/*, etc.

PassengerEnabled on
PassengerAppRoot /home/xqyvotdh/repositories/rocket1
PassengerPython /home/xqyvotdh/virtualenv/repositories/rocket1/3.13/bin/python3

