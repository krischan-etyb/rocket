# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-this-in-production

# Email Service Configuration (choose sendgrid or mailgun)
EMAIL_SERVICE=sendgrid

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Mailgun Configuration (if using Mailgun - alternative to SendGrid)
# MAILGUN_API_KEY=your-mailgun-api-key-here
# MAILGUN_DOMAIN=your-domain.mailgun.org

# Email Addresses
COMPANY_EMAIL=info@rocketlogistic.bg
COMPANY_NAME=Rocket Logistic

# CORS Configuration
# Development: http://localhost:5500,http://127.0.0.1:5500
# Production: https://rocketlogistic.bg,https://www.rocketlogistic.bg
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting
MAX_SUBMISSIONS_PER_HOUR=5

# Server Configuration
PORT=5000
DEBUG=True
